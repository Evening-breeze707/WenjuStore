<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">

<mapper namespace="com.dao.YuleshangpinDao">

	<!-- 可根据自己的需求，是否要使用 -->
    <resultMap type="com.entity.YuleshangpinEntity" id="yuleshangpinMap">
        <result property="shangpinmingcheng" column="shangpinmingcheng"/>
        <result property="shangpinpinpai" column="shangpinpinpai"/>
        <result property="shangpinguige" column="shangpinguige"/>
        <result property="shangpintupian" column="shangpintupian"/>
        <result property="shangpinxiangqing" column="shangpinxiangqing"/>
        <result property="onelimittimes" column="onelimittimes"/>
        <result property="alllimittimes" column="alllimittimes"/>
        <result property="clicktime" column="clicktime"/>
        <result property="clicknum" column="clicknum"/>
        <result property="price" column="price"/>
    </resultMap>

	<select id="selectListVO"
		resultType="com.entity.vo.YuleshangpinVO" >
		SELECT * FROM yuleshangpin  yuleshangpin         
        <where> 1=1 ${ew.sqlSegment}</where>
	</select>
	
	<select id="selectVO"
		resultType="com.entity.vo.YuleshangpinVO" >
		SELECT  yuleshangpin.* FROM yuleshangpin  yuleshangpin 	
 		<where> 1=1 ${ew.sqlSegment}</where>
	</select>

    <select id="selectListView"
		resultType="com.entity.view.YuleshangpinView" >

		SELECT  yuleshangpin.* FROM yuleshangpin  yuleshangpin 	        
        <where> 1=1 ${ew.sqlSegment}</where>
	</select>
	
	<select id="selectView"
		resultType="com.entity.view.YuleshangpinView" >
		SELECT * FROM yuleshangpin  yuleshangpin <where> 1=1 ${ew.sqlSegment}</where>
	</select>
	

</mapper>
